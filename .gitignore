# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local SRS state. The DB lives outside the repo by default, but if a user
# overrides DUTCH_SRS_DB to a path inside the project they should not commit
# their personal review history.
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# Logs
logs/*
!logs/.gitkeep

# Per-machine sentence-audio leftovers from the pre-hash scheme. The
# repo ships hash-named files (16 hex chars + .mp3); these patterns
# catch the old numeric-id names and any sandbox temp files that
# should never be committed.
app/static/audio/sentences/[0-9]*.mp3

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp

# Secrets
.env
.env.*
*.json
!package.json
!data/*.json
!app/static/**/*.json
Lest Best Classes/
