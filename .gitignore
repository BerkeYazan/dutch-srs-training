# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local SRS state. The DB lives outside the repo by default, but if a user
# overrides DUTCH_SRS_DB to a path inside the project they should not commit
# their personal review history.
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# Logs
logs/*
!logs/.gitkeep

# Per-machine sentence-audio leftovers from the pre-hash scheme.
# Match numeric-only stems of one to four digits. Hash-named files
# (16 hex chars) include both letters and digits and must not be
# excluded, an earlier rule of [0-9]*.mp3 was too greedy and ate
# hash names starting with 0-9 (about 37 percent of the set).
app/static/audio/sentences/[0-9].mp3
app/static/audio/sentences/[0-9][0-9].mp3
app/static/audio/sentences/[0-9][0-9][0-9].mp3
app/static/audio/sentences/[0-9][0-9][0-9][0-9].mp3

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp

# Secrets
.env
.env.*
*.json
!package.json
!data/*.json
!app/static/**/*.json
Lest Best Classes/
